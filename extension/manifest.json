{
  "manifest_version": 3,
  "name": "네이버 증권 수급 분석기",
  "description": "네이버 증권 장기 수급 데이터를 그래프와 수급 기준 매수·매도 전략으로 분석합니다.",
  "version": "1.3.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "네이버 증권 수급 분석기",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://finance.naver.com/*",
    "https://m.stock.naver.com/*",
    "https://ac.stock.naver.com/*"
  ]
}
